# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=predikt_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=predikt_db

# ─── pgAdmin ─────────────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@predikt.local
PGADMIN_DEFAULT_PASSWORD=pgadmin_secret

# ─── API ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:8081,http://localhost:8082,http://127.0.0.1:8081,http://127.0.0.1:8082

# Prisma connection string — matches the postgres values above
DATABASE_URL=postgresql://predikt_user:change_me_in_production@postgres:5432/predikt_db?schema=public

# JWT — use long random strings in production
JWT_SECRET=replace_with_a_long_random_access_secret
ADMIN_JWT_SECRET=replace_with_a_long_random_admin_secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
ADMIN_JWT_TTL_SECONDS=3600

# Optional maps provider keys
# MAPS_PROVIDER=auto
# OLA_MAPS_API_KEY=               # Enables Ola Maps Web SDK and future Ola search/routing integration.
# GOOGLE_MAPS_API_KEY=            # Enables Google place search and route ETA when Places/Directions keys are not split.
# GOOGLE_PLACES_API_KEY=          # Optional split key for Google place search.
# GOOGLE_DIRECTIONS_API_KEY=      # Optional split key for Google Directions ETA.
# BING_MAPS_API_KEY=
# AZURE_MAPS_KEY=
# OSRM_BASE_URL=http://localhost:5000
