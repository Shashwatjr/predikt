# PREDIKT mobile web — production build env (Option 2)
# Used when exporting the Expo web bundle that you upload to kriviksha.com/predikt.
# Copy to .env.production (or pass inline) before `npx expo export --platform web`.

# The deployed backend origin (see DEPLOYMENT_PREDIKT.md — api.kriviksha.com).
EXPO_PUBLIC_API_BASE_URL=https://api.kriviksha.com

# Where the web app itself is served. Invite links become:
#   https://kriviksha.com/predikt?joinCode=CODE
EXPO_PUBLIC_WEB_BASE_URL=https://kriviksha.com/predikt

# --- Optional feature-flag overrides (defaults live in src/config/featureFlags.ts) ---
# EXPO_PUBLIC_FEATURE_LEADERBOARD=false
# EXPO_PUBLIC_FEATURE_NOTIFICATIONS=false
