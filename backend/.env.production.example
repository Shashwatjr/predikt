# PREDIKT backend — production (Option 2: managed host + Neon Postgres)
# Copy the values into your host's environment settings (Render/Railway dashboard).
# Do NOT commit real secrets.

NODE_ENV=production
PORT=3000

# Neon Postgres connection string (Dashboard → Connection Details → "Prisma").
# Must include ?sslmode=require. Example shape:
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/predikt_db?sslmode=require

# Long random secrets — generate with:  openssl rand -hex 48
JWT_SECRET=__replace_with_64+_random_chars__
ADMIN_JWT_SECRET=__replace_with_64+_random_chars__
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=30
ADMIN_JWT_TTL_SECONDS=3600

# Comma-separated allowed browser origins. In production ONLY these are allowed.
# The frontend lives at kriviksha.com/predikt, so the origin is the bare domain:
CORS_ORIGINS=https://kriviksha.com,https://www.kriviksha.com

# Used to build invite links inside share text returned by the API.
WEB_BASE_URL=https://kriviksha.com/predikt

# --- Optional feature-flag overrides (defaults live in src/config/feature-flags.ts) ---
# FEATURE_GUEST_JOIN=true
# FEATURE_REMATCH=true
