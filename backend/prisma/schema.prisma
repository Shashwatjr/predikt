generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoomStatus {
  created
  predictions_open
  predictions_locked
  live
  completed
  cancelled
}

enum Visibility {
  private
  invite_only
  public
}

enum LocationDisplayMode {
  ghost
  approximate
  delayed
  exact
  progress
  fuzzy
  delayed_trail
  trusted_circle
  verified_arrival
}

enum PredictionVisibilityMode {
  hidden_until_lock
  visible_after_submit
  creator_visible
}

enum ReportType {
  harassment
  spam
  betting_or_cash
  unsafe_location
  inappropriate_content
  fake_result
  other
}

enum ReportStatus {
  submitted
  in_review
  resolved
  dismissed
}

enum DisputeStatus {
  submitted
  in_review
  resolved
  dismissed
}

enum MilestoneType {
  intermediate
  final_destination
}

enum MilestoneStatus {
  pending
  prediction_open
  prediction_locked
  reached
  cancelled
}

enum CloutTransactionType {
  earn
  spend
  adjustment
  expire
}

enum DropType {
  voucher
  flex
  aura_boost
  creator_perk
  mystery_drop
}

enum DropStatus {
  active
  inactive
  expired
}

enum UserDropStatus {
  unlocked
  redeemed
  expired
}

enum RoomDropRuleType {
  overall_winner
  exact_hit
  beat_ai
  clout_unlock
  milestone_winner
}

enum FlexType {
  exact_hit
  dot_hunter
  dot_master
  sharp_shot
  near_perfect
  streak
  beat_ai
  milestone_master
  room_champion
  early_user
}

enum SocialMode {
  none
  instagram_live
  facebook_live
  youtube_live
  custom
}

enum RoomCategory {
  journey
  milestone_journey
  fitness
  delivery
  travel
  creator_challenge
  brand_room
  ai_vs_human
  custom
}

enum MovementAvatarType {
  car
  bike
  delivery_bike
  walker
  runner
  truck
  train
  flight
  bus
  custom
}

enum CreatorVerificationStatus {
  pending_review
  verified
  active
  suspended
  rejected
}

enum PlanType {
  free
  creator_starter
  creator_pro
  creator_max
  brand_starter
  brand_growth
  enterprise
}

enum PlanStatus {
  active
  inactive
  deprecated
}

enum SponsorStatus {
  active
  inactive
  pending_review
  suspended
}

enum CampaignType {
  sponsored_journey
  delivery_dash
  road_trip_challenge
  fitness_challenge
  creator_live
  brand_room
  ai_vs_human
  custom
}

enum CampaignStatus {
  draft
  pending_approval
  active
  paused
  completed
  cancelled
}

enum AdminStatus {
  active
  suspended
  disabled
}

enum ConsentType {
  terms_acceptance
  privacy_policy_acceptance
  location_processing
  creator_public_profile
  marketing_communications
  sponsored_campaign_participation
  analytics_processing
  ai_prediction_comparison
}

enum ConsentStatus {
  granted
  withdrawn
  denied
}

enum PrivacyRequestType {
  access
  delete
  rectify
  export
  restrict
  object
  withdraw_consent
}

enum PrivacyRequestStatus {
  submitted
  in_review
  verified
  processing
  completed
  rejected
}

enum AiSystemStatus {
  planned
  active
  retired
}

model User {
  userId                  String          @id @default(uuid()) @map("user_id")
  name                    String
  email                   String?         @unique
  phone                   String?         @unique
  prediktHandle           String?         @unique @map("predikt_handle")
  profileImage            String?         @map("profile_image")
  avatarKey               String?         @map("avatar_key")
  selectedBackgroundKey   String?         @map("selected_background_key")
  passwordHash            String?         @map("password_hash")
  isGuest                 Boolean         @default(false) @map("is_guest")
  guestKey                String?         @unique @map("guest_key")
  status                  String          @default("active")
  totalAura               Int             @default(0) @map("total_aura")
  weeklyAura              Int             @default(0) @map("weekly_aura")
  cloutBalance            Int             @default(0) @map("clout_balance")
  lifetimeCloutEarned     Int             @default(0) @map("lifetime_clout_earned")
  creditBalance           Int             @default(0) @map("credit_balance")
  predictionAccuracyScore Float           @default(0) @map("prediction_accuracy_score")
  roomsCreatedCount       Int             @default(0) @map("rooms_created_count")
  predictionsMadeCount    Int             @default(0) @map("predictions_made_count")
  winsCount               Int             @default(0) @map("wins_count")
  currentStreak           Int             @default(0) @map("current_streak")
  longestStreak           Int             @default(0) @map("longest_streak")
  termsAcceptedAt         DateTime?       @map("terms_accepted_at")
  privacyAcceptedAt       DateTime?       @map("privacy_accepted_at")
  marketingOptIn          Boolean         @default(false) @map("marketing_opt_in")
  aiPersonalisationOptOut Boolean         @default(false) @map("ai_personalisation_opt_out")
  preferredCommentaryPersonality String?    @map("preferred_commentary_personality")
  aiCommentaryOptOut      Boolean         @default(false) @map("ai_commentary_opt_out")
  commentaryEnabled        Boolean         @default(true) @map("commentary_enabled")
  commentaryToneLevel     String          @default("playful") @map("commentary_tone_level")
  locationConsentStatus   String?         @map("location_consent_status")
  createdAt               DateTime        @default(now()) @map("created_at")
  updatedAt               DateTime        @updatedAt @map("updated_at")

  rooms                 PredictionRoom[]      @relation("creator_rooms")
  milestonePredictions  MilestonePrediction[]
  locationEvents        LiveLocationEvent[]
  auraTransactions      AuraTransaction[]
  cloutTransactions     CloutTransaction[]
  roomResults           RoomResult[]
  userDrops             UserDrop[]
  userFlexes            UserFlex[]
  creatorProfile        CreatorProfile?
  createdCampaigns      Campaign[]            @relation("creator_campaigns")
  consentRecords        ConsentRecord[]
  privacyRequests       PrivacyRequest[]      @relation("privacy_request_user")
  creditLedger          CreditLedger[]
  sessions              UserSession[]
  reportsFiled          Report[]              @relation("reporter_reports")
  reportsReceived       Report[]              @relation("target_user_reports")
  blockedUsers          UserBlock[]           @relation("user_blocks")
  blockedByUsers        UserBlock[]           @relation("user_blocked_by")
  roomDisputes          RoomDispute[]
  resultReactions       ResultReaction[]
  following             Follow[]              @relation("Following")
  followers             Follow[]              @relation("Followers")
  dailySpinClaims       DailySpinClaim[]
  activityEvents        ActivityEvent[]
  feedbackSubmissions   UserFeedback[]
  roomPreferences       UserRoomPreference[]
  reliabilityLedger     UserReliabilityLedger[]
  roomMemberships       RoomMembership[]
  notifications         UserNotification[]
  roomCommentaries      RoomCommentary[]      @relation("generatedBy")
  userBadges            UserBadge[]

  @@map("users")
}

model PredictionRoom {
  roomId                    String              @id @default(uuid()) @map("room_id")
  creatorUserId             String              @map("creator_user_id")
  roomTitle                 String              @map("room_title")
  eventType                 String              @map("event_type")
  category                  String?             @map("category")
  mode                      String?             @map("mode")
  templateKey               String?             @map("template_key")
  baselineSource            String?             @map("baseline_source")
  baselineLabel             String?             @map("baseline_label")
  baselineValue             Json?               @map("baseline_value")
  baselineSnapshot          Json?               @map("baseline_snapshot")
  baselineCapturedAt        DateTime?           @map("baseline_captured_at")
  providerName              String?             @map("provider_name")
  providerConfidence        String?             @map("provider_confidence")
  hostPrediction            Json?               @map("host_prediction")
  oracleBotPrediction       Json?               @map("oracle_bot_prediction")
  // v2 (checkpoint_leaderboard_v2): Oracle's SCORED outcome as a ranked competitor
  // ({ arrivalTime, diffSeconds, rank, beatenByHuman, frozenAtCheckpoint }). Distinct from
  // oracleBotPrediction, which is only the display benchmark label.
  oracleResult              Json?               @map("oracle_result")
  options                   Json?               @map("options")
  roomType                  String              @default("journey") @map("room_type")
  answerType                String              @default("exact_time") @map("answer_type")
  predictionMode            String              @default("milestone") @map("prediction_mode")
  predictionVisibilityMode  PredictionVisibilityMode @default(hidden_until_lock) @map("prediction_visibility_mode")
  roomCategory              RoomCategory        @default(journey) @map("room_category")
  startingPointLabel        String              @map("starting_point_label")
  destinationLabel          String              @map("destination_label")
  startingLat               Float?              @map("starting_lat")
  startingLng               Float?              @map("starting_lng")
  destinationLat            Float?              @map("destination_lat")
  destinationLng            Float?              @map("destination_lng")
  status                    RoomStatus          @default(created)
  visibility                Visibility          @default(invite_only)
  locationDisplayMode       LocationDisplayMode @default(approximate) @map("location_display_mode")
  safetyDelayMinutes        Int                 @default(10) @map("safety_delay_minutes")
  visibleMovementStartTime  DateTime?           @map("visible_movement_start_time")
  disableRouteReplay        Boolean             @default(true) @map("disable_route_replay")
  hideExactStart            Boolean             @default(true) @map("hide_exact_start")
  hideExactDestination      Boolean             @default(true) @map("hide_exact_destination")
  autoPauseNearDestination  Boolean             @default(true) @map("auto_pause_near_destination")
  socialMode                SocialMode          @default(none) @map("social_mode")
  creatorSocialPlatform     String?             @map("creator_social_platform")
  creatorSocialHandle       String?             @map("creator_social_handle")
  socialLiveUrl             String?             @map("social_live_url")
  pinnedCommentText         String?             @map("pinned_comment_text")
  shareCardTitle            String?             @map("share_card_title")
  shareCardSubtitle         String?             @map("share_card_subtitle")
  instagramStoryText        String?             @map("instagram_story_text")
  facebookPostText          String?             @map("facebook_post_text")
  qrCodePayload             String?             @map("qr_code_payload")
  resultShareText           String?             @map("result_share_text")
  movementAvatarType        MovementAvatarType  @default(car) @map("movement_avatar_type")
  movementAvatarUrl         String?             @map("movement_avatar_url")
  isSponsored               Boolean             @default(false) @map("is_sponsored")
  sponsorName               String?             @map("sponsor_name")
  sponsorLogoUrl            String?             @map("sponsor_logo_url")
  sponsorBrandColor         String?             @map("sponsor_brand_color")
  sponsorTagline            String?             @map("sponsor_tagline")
  resultCardSponsorText     String?             @map("result_card_sponsor_text")
  inviteCode                String              @unique @map("invite_code")
  rematchOfRoomId           String?             @map("rematch_of_room_id")
  plannedStartTime          DateTime?           @map("planned_start_time")
  startTime                 DateTime?           @map("start_time")
  predictionCloseTime       DateTime            @map("prediction_close_time")
  lockTime                  DateTime?           @map("lock_time")
  editDeadline              DateTime?           @map("edit_deadline")
  resultDeadline            DateTime?           @map("result_deadline")
  journeyStatus             String              @default("scheduled") @map("journey_status")
  journeyScheduledStartAt   DateTime?           @map("journey_scheduled_start_at")
  journeyStartedAt          DateTime?           @map("journey_started_at")
  lastTravellerUpdateAt     DateTime?           @map("last_traveller_update_at")
  expectedDurationSeconds   Int?                @map("expected_duration_seconds")
  gracePeriodSeconds        Int?                @map("grace_period_seconds")
  autoCloseAt               DateTime?           @map("auto_close_at")
  noStartCutoffAt           DateTime?           @map("no_start_cutoff_at")
  arrivalConfirmedAt        DateTime?           @map("arrival_confirmed_at")
  cancelledAt               DateTime?           @map("cancelled_at")
  autoClosedAt              DateTime?           @map("auto_closed_at")
  abandonedAt               DateTime?           @map("abandoned_at")
  closureReasonCode         String?             @map("closure_reason_code")
  closureNote               String?             @map("closure_note")
  scoringRule               Json?               @map("scoring_rule")
  outcomeSource             String?             @map("outcome_source")
  confidenceLevel           String?             @map("confidence_level")
  selectedBackground        String?             @map("selected_background")
  selectedRoomTheme         String?             @map("selected_room_theme")
  participantSafetyMessage  String              @default("Location shown with delay for safety.") @map("participant_safety_message")
  resultDisputed            Boolean             @default(false) @map("result_disputed")
  rewardsSuppressed         Boolean             @default(false) @map("rewards_suppressed")
  actualEndTime             DateTime?           @map("actual_end_time")
  aiPredictedTime           DateTime?           @map("ai_predicted_time")
  mapPredictedTime          DateTime?           @map("map_predicted_time")
  crowdAverageTime          DateTime?           @map("crowd_average_time")
  createdAt                 DateTime            @default(now()) @map("created_at")
  updatedAt                 DateTime            @updatedAt @map("updated_at")

  creator               User                  @relation("creator_rooms", fields: [creatorUserId], references: [userId])
  rematchOfRoom         PredictionRoom?       @relation("RoomRematch", fields: [rematchOfRoomId], references: [roomId])
  rematches             PredictionRoom[]      @relation("RoomRematch")
  milestones            RoomMilestone[]
  milestonePredictions  MilestonePrediction[]
  results               RoomResult[]
  locationEvents        LiveLocationEvent[]
  checkpoints          RoomCheckpoint[]
  auraTransactions      AuraTransaction[]
  cloutTransactions     CloutTransaction[]
  roomDropRules         RoomDropRule[]
  userDrops             UserDrop[]
  userFlexes            UserFlex[]
  creditLedger          CreditLedger[]
  reports               Report[]
  disputes              RoomDispute[]
  resultReactions       ResultReaction[]
  campaignMetrics       CampaignMetric[]
  journeyRoute          JourneyRoute?
  roomPreferences       UserRoomPreference[]
  reliabilityLedger     UserReliabilityLedger[]
  roomMemberships       RoomMembership[]
  notifications         UserNotification[]
  roomCommentaries      RoomCommentary[]
  userBadges            UserBadge[]

  @@map("prediction_rooms")
}

model RoomCheckpoint {
  roomCheckpointId String   @id @default(uuid()) @map("room_checkpoint_id")
  roomId           String   @map("room_id")
  checkpoint       Int      @map("checkpoint")
  lat              Float    @map("lat")
  lng              Float    @map("lng")
  capturedAt       DateTime @map("captured_at")
  // v2 checkpoint scheme (checkpoint_leaderboard_v2): ETA re-read captured at this
  // checkpoint and its source. "google" for the 20/40/60/80 live re-reads, "derived"
  // for the free 90/100 pace-projected values. Null on legacy 0/50/80/100 rows.
  etaSeconds       Int?     @map("eta_seconds")
  source           String?  @map("source")
  createdAt        DateTime @default(now()) @map("created_at")

  room PredictionRoom @relation(fields: [roomId], references: [roomId])

  @@unique([roomId, checkpoint])
  @@index([roomId, capturedAt])
  @@map("room_checkpoints")
}

model RoomCommentary {
  commentaryId              String   @id @default(uuid()) @map("commentary_id")
  roomId                   String   @map("room_id")
  generatedByUserId        String?  @map("generated_by_user_id")
  personality              String
  headline                 String
  punchline                String
  supportingLine           String?  @map("supporting_line")
  safetyMode               String   @default("deterministic") @map("safety_mode")
  provider                 String   @default("templates")
  providerVersion          String?  @map("provider_version")
  templateKey              String?  @map("template_key")
  generationVersion        Int      @default(1) @map("generation_version")
  generatedAt              DateTime @default(now()) @map("generated_at")
  regeneratedAt            DateTime? @map("regenerated_at")
  moderationStatus         String   @default("approved") @map("moderation_status")
  moderationReason         String?  @map("moderation_reason")
  reportedCount            Int      @default(0) @map("reported_count")
  isCurrent                Boolean  @default(true) @map("is_current")
  metadata                 Json?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  room        PredictionRoom @relation(fields: [roomId], references: [roomId])
  generatedBy User?          @relation("generatedBy", fields: [generatedByUserId], references: [userId])

  @@index([roomId])
  @@index([roomId, isCurrent])
  @@index([moderationStatus])
  @@map("room_commentaries")
}

model UserBadge {
  userBadgeId  String   @id @default(uuid()) @map("user_badge_id")
  userId       String   @map("user_id")
  badgeKey     String   @map("badge_key")
  roomId       String?  @map("room_id")
  category     String?
  title        String
  description  String
  icon         String?
  awardedAt    DateTime @default(now()) @map("awarded_at")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")

  user User            @relation(fields: [userId], references: [userId])
  room PredictionRoom? @relation(fields: [roomId], references: [roomId])

  @@unique([userId, roomId, badgeKey])
  @@index([userId, awardedAt])
  @@index([badgeKey])
  @@index([roomId])
  @@map("user_badges")
}

model RoomMilestone {
  milestoneId           String            @id @default(uuid()) @map("milestone_id")
  roomId                String            @map("room_id")
  milestoneOrder        Int               @map("milestone_order")
  milestoneName         String            @map("milestone_name")
  milestoneType         MilestoneType     @default(intermediate) @map("milestone_type")
  locationLabel         String?           @map("location_label")
  milestoneLat          Float?            @map("milestone_lat")
  milestoneLng          Float?            @map("milestone_lng")
  predictionCloseTime   DateTime?         @map("prediction_close_time")
  actualReachedTime     DateTime?         @map("actual_reached_time")
  actualOptionKey       String?           @map("actual_option_key")
  status                MilestoneStatus   @default(pending)
  auraMultiplier        Decimal           @default(1.0) @db.Decimal(5, 2) @map("aura_multiplier")
  createdAt             DateTime          @default(now()) @map("created_at")
  updatedAt             DateTime          @updatedAt @map("updated_at")

  room                  PredictionRoom        @relation(fields: [roomId], references: [roomId])
  milestonePredictions  MilestonePrediction[]
  auraTransactions      AuraTransaction[]
  cloutTransactions     CloutTransaction[]
  currentLocationEvents LiveLocationEvent[]
  userFlexes            UserFlex[]

  @@unique([roomId, milestoneOrder])
  @@map("room_milestones")
}

model MilestonePrediction {
  predictionId                String   @id @default(uuid()) @map("prediction_id")
  milestoneId                 String   @map("milestone_id")
  roomId                      String   @map("room_id")
  userId                      String   @map("user_id")
  predictedReachedTime        DateTime @map("predicted_reached_time")
  selectedOptionKey           String?  @map("selected_option_key")
  submittedAt                 DateTime @default(now()) @map("submitted_at")
  editDeadline                DateTime? @map("edit_deadline")
  revokedAt                   DateTime? @map("revoked_at")
  lockedStatus                Boolean  @default(false) @map("locked_status")
  differenceFromActualMinutes Float?   @map("difference_from_actual_minutes")
  differenceFromActualSeconds Int?     @map("difference_from_actual_seconds")
  rankForMilestone            Int?     @map("rank_for_milestone")
  baseAura                    Int      @default(0) @map("base_aura")
  rankBonusAura               Int      @default(0) @map("rank_bonus_aura")
  multiplier                  Decimal  @default(1.0) @db.Decimal(5, 2)
  totalAuraAwarded            Int      @default(0) @map("total_aura_awarded")
  cloutAwarded                Int      @default(0) @map("clout_awarded")
  // v2 (checkpoint_leaderboard_v2): predictions locked after the 80% checkpoint are
  // accepted but Rizz-tier only — auraEligible=false excludes them from the winner /
  // Aura leaderboard. lockedCheckpoint records the checkpoint % at which it locked.
  auraEligible                Boolean  @default(true) @map("aura_eligible")
  lockedCheckpoint            Int?     @map("locked_checkpoint")

  milestone RoomMilestone @relation(fields: [milestoneId], references: [milestoneId])
  room      PredictionRoom @relation(fields: [roomId], references: [roomId])
  user      User           @relation(fields: [userId], references: [userId])

  @@unique([milestoneId, userId])
  @@map("milestone_predictions")
}

model RoomResult {
  roomResultId   String   @id @default(uuid()) @map("room_result_id")
  roomId         String   @map("room_id")
  userId         String   @map("user_id")
  totalRoomAura  Int      @default(0) @map("total_room_aura")
  totalRoomClout Int      @default(0) @map("total_room_clout")
  milestonesWon  Int      @default(0) @map("milestones_won")
  overallRank    Int?     @map("overall_rank")
  createdAt      DateTime @default(now()) @map("created_at")

  predictionRoom PredictionRoom @relation(fields: [roomId], references: [roomId])
  user           User           @relation(fields: [userId], references: [userId])

  @@unique([roomId, userId])
  @@map("room_results")
}

model UserRoomPreference {
  userRoomPreferenceId String         @id @default(uuid()) @map("user_room_preference_id")
  userId               String         @map("user_id")
  roomId               String         @map("room_id")
  pinned               Boolean        @default(false)
  displayOrder         Int            @default(0) @map("display_order")
  hiddenFromDashboard  Boolean        @default(false) @map("hidden_from_dashboard")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [userId])
  room PredictionRoom @relation(fields: [roomId], references: [roomId])

  @@unique([userId, roomId])
  @@map("user_room_preferences")
}

model RoomMembership {
  membershipId String    @id @default(uuid()) @map("membership_id")
  roomId       String    @map("room_id")
  userId       String    @map("user_id")
  role         String
  status       String
  joinedAt     DateTime  @map("joined_at")
  leftAt       DateTime? @map("left_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  room PredictionRoom @relation(fields: [roomId], references: [roomId])
  user User           @relation(fields: [userId], references: [userId])

  @@unique([roomId, userId])
  @@index([userId])
  @@index([roomId])
  @@index([status])
  @@map("room_memberships")
}

model UserNotification {
  notificationId String    @id @default(uuid()) @map("notification_id")
  userId         String    @map("user_id")
  roomId         String?   @map("room_id")
  type           String
  title          String
  body           String
  status         String
  severity       String
  actionLabel    String?   @map("action_label")
  actionTarget   String?   @map("action_target")
  metadata       Json?
  createdAt      DateTime  @default(now()) @map("created_at")
  readAt         DateTime? @map("read_at")

  user User            @relation(fields: [userId], references: [userId])
  room PredictionRoom? @relation(fields: [roomId], references: [roomId])

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([roomId])
  @@map("user_notifications")
}

model UserReliabilityLedger {
  reliabilityLedgerId String   @id @default(uuid()) @map("reliability_ledger_id")
  userId              String   @map("user_id")
  roomId              String?  @map("room_id")
  eventType           String   @map("event_type")
  pointsDelta         Int      @map("points_delta")
  reason              String
  metadata            Json?
  createdAt           DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId])
  room PredictionRoom? @relation(fields: [roomId], references: [roomId])

  @@map("user_reliability_ledger")
}

model LiveLocationEvent {
  locationEventId     String              @id @default(uuid()) @map("location_event_id")
  roomId              String              @map("room_id")
  creatorUserId       String              @map("creator_user_id")
  rawLat              Float?              @map("raw_lat")
  rawLng              Float?              @map("raw_lng")
  progressPercentage  Float?              @map("progress_percentage")
  etaMinutes          Int?                @map("eta_minutes")
  displayLat          Float?              @map("display_lat")
  displayLng          Float?              @map("display_lng")
  currentMilestoneId  String?             @map("current_milestone_id")
  locationDisplayMode LocationDisplayMode @default(approximate) @map("location_display_mode")
  createdAt           DateTime            @default(now()) @map("created_at")

  room             PredictionRoom @relation(fields: [roomId], references: [roomId])
  creator          User           @relation(fields: [creatorUserId], references: [userId])
  currentMilestone RoomMilestone? @relation(fields: [currentMilestoneId], references: [milestoneId])

  @@map("live_location_events")
}

model AuraTransaction {
